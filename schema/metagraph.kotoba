// Metagraph clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace metagraph {

    entity Campaign {
        id: string @unique
        name: string
        channel: string
        status: string
        budget: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Audience {
        id: string @unique
        name: string
        size: integer
        definition: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Event {
        id: string @unique
        profileId: string
        name: string
        properties: string
        occurredAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Profile {
        id: string @unique
        email: string
        externalId: string
        traits: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Message {
        id: string @unique
        campaignId: string
        profileId: string
        channel: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Funnel {
        id: string @unique
        name: string
        steps: string
        conversionRate: float
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
